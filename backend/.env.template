# ============================================================
# AuraCV resume backend — environment variables
# Copy to .env and fill in:   cp .env.template .env
# ============================================================

# ---------- OpenAI ----------
# Required. Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model used for extraction. gpt-4.1 is the best accuracy/cost balance for
# structured resume parsing. Use gpt-4.1-mini for cheaper/faster runs.
OPENAI_MODEL=gpt-4.1
OPENAI_MAX_TOKENS=8000

# ---------- LlamaParse (PDF text extraction) ----------
# Required for /extract-pdf. Create a key at https://cloud.llamaindex.ai
LLAMA_CLOUD_API_KEY=
# Parsing tier: fast | cost_effective | agentic | agentic_plus.
# cost_effective is the sweet spot for text-based resumes.
LLAMA_TIER=cost_effective
# Parser version pin; "latest" tracks the newest release.
LLAMA_PARSE_VERSION=latest
# Max seconds for a single parse (incl. polling) before failing the request.
LLAMA_TIMEOUT=120

# ---------- HTTP fetching ----------
REQUEST_TIMEOUT=30
# Max resume PDF download size in bytes (default 10 MB).
MAX_PDF_BYTES=10485760

# ---------- CORS ----------
# Comma-separated origins allowed to call this API from the browser.
# Add your production frontend URL here, e.g. https://auracv.me
CORS_ORIGINS=http://localhost:3000
